export default async function Home(){const res=await fetch(`https://api.themoviedb.org/3/trending/movie/day?api_key=${process.env.NEXT_PUBLIC_TMDB_KEY}`);const data=await res.json();return(<div><h1>热门电影</h1>{data.results.map(m=>(<div key={m.id}><a href={`/movie/${m.id}`}>{m.title}</a></div>))}</div>)}
